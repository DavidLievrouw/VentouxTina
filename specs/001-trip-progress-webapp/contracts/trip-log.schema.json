{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ventouxtina.local/schemas/trip-log.schema.json",
  "title": "Trip Log Source",
  "description": "Schema for manual JSON/YAML trip log source file",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entryId", "date", "kilometers", "activity"],
        "properties": {
          "entryId": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "kilometers": {
            "type": "number",
            "minimum": 0
          },
          "activity": {
            "type": "string",
            "enum": ["running", "cycling", "walking"]
          },
          "isCorrection": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}