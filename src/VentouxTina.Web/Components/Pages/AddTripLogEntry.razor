@page "/beheer/logboek"
@using Microsoft.AspNetCore.Authorization
@using VentouxTina.Web.Domain.Models
@using VentouxTina.Web.Domain.Services
@using VentouxTina.Web.Infrastructure.DataSources
@attribute [Authorize]
@inject ITripLogWriteService WriteService
@inject IProgressService ProgressService

<PageTitle>Activiteit toevoegen – Ventoux Tina</PageTitle>

<section class="section">
    <h2 class="section-title">Activiteit toevoegen</h2>

    @if (_saved)
    {
        <div class="success-message" role="status">
            ✅ Activiteit succesvol opgeslagen!
            <button class="btn-link" @onclick="ResetForm">Nog een toevoegen</button>
        </div>
    }
    else
    {
        <form class="entry-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault>

            @if (_errors.Count > 0)
            {
                <ul class="form-errors" role="alert">
                    @foreach (var err in _errors)
                    {
                        <li>@err</li>
                    }
                </ul>
            }

            <div class="form-field">
                <label for="timestamp">Datum &amp; tijd</label>
                <input id="timestamp"
                       type="datetime-local"
                       value="@_timestampLocalStr"
                       @onchange="OnTimestampChanged"
                       required/>
                @if (_minTimestamp is not null)
                {
                    <small class="field-hint">Moet na @_minTimestamp.Value.ToString("dd/MM/yyyy HH:mm") liggen (laatste
                        activiteit).</small>
                }
            </div>

            <div class="form-field">
                <label for="activity">Activiteit</label>
                <select id="activity" @bind="_activity" required>
                    <option value="">— kies —</option>
                    <option value="running">Lopen</option>
                    <option value="cycling">Fietsen</option>
                    <option value="walking">Wandelen</option>
                </select>
            </div>

            <div class="form-field">
                <label for="kilometers">Kilometers (0.1 – 100)</label>
                <input id="kilometers"
                       type="number"
                       step="0.1"
                       min="0.1"
                       max="100"
                       @bind="_kilometers"
                       required/>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary" disabled="@_busy">
                    @(_busy ? "Opslaan…" : "Opslaan")
                </button>
                <a href="/logboek" class="btn-link">Terug naar logboek</a>
            </div>
        </form>
    }
</section>

@code {

    private DateTime _timestampLocal = DateTime.Now;

    // One-way string fed into the input's value attribute — only set on init/reset,
    // never overwritten on re-render, so Blazor won't clobber what the user typed.
    private string _timestampLocalStr = string.Empty;
    private string _activity = string.Empty;
    private decimal _kilometers = 5.0m;

    private DateTime? _minTimestamp;
    private readonly List<string> _errors = [];
    private bool _busy;
    private bool _saved;

    protected override async Task OnInitializedAsync()
    {
        var latest = await WriteService.GetLatestTimestampAsync();
        _minTimestamp = latest.HasValue ? latest.Value.ToLocalTime() : null;

        _timestampLocal = DateTime.Now;
        if (_minTimestamp.HasValue && _timestampLocal <= _minTimestamp.Value)
            _timestampLocal = _minTimestamp.Value.AddMinutes(1);

        _timestampLocalStr = _timestampLocal.ToString("yyyy-MM-ddTHH:mm");
    }

    private void OnTimestampChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsed))
            _timestampLocal = parsed;
    }

    private async Task HandleSubmit()
    {
        _errors.Clear();
        Validate();

        if (_errors.Count > 0)
            return;

        _busy = true;
        StateHasChanged();

        try
        {
            var entry = new TripLogEntry
            {
                EntryId = Guid.NewGuid().ToString(),
                // Store as UTC
                Timestamp = _timestampLocal.ToUniversalTime(),
                Kilometers = _kilometers,
                Activity = _activity,
            };

            await WriteService.AddEntryAsync(entry);
            ProgressService.InvalidateCache();
            _saved = true;
        }
        catch (Exception ex)
        {
            _errors.Add($"Fout bij opslaan: {ex.Message}");
        }
        finally
        {
            _busy = false;
        }
    }

    private void Validate()
    {
        if (_timestampLocal == default)
            _errors.Add("Geef een geldige datum en tijd op.");

        if (_minTimestamp.HasValue && _timestampLocal <= _minTimestamp.Value)
            _errors.Add($"Tijdstip moet na {_minTimestamp.Value:dd/MM/yyyy HH:mm} liggen (het tijdstip van de laatste activiteit).");

        if (_timestampLocal > DateTime.Now.AddHours(1))
            _errors.Add("Tijdstip mag niet meer dan 1 uur in de toekomst liggen.");

        if (string.IsNullOrWhiteSpace(_activity))
            _errors.Add("Kies een activiteit.");

        if (_kilometers < 0.1m || _kilometers > 100m)
            _errors.Add("Kilometers moet tussen 0,1 en 100 liggen.");
    }

    private void ResetForm()
    {
        _saved = false;
        _errors.Clear();
        _activity = string.Empty;
        _kilometers = 5.0m;
        _timestampLocal = _minTimestamp.HasValue
            ? _minTimestamp.Value.AddMinutes(1)
            : DateTime.Now;
        _timestampLocalStr = _timestampLocal.ToString("yyyy-MM-ddTHH:mm");
    }

}

