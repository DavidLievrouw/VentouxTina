@using Microsoft.AspNetCore.Components.Authorization
@using VentouxTina.Web.Domain.Models
@using VentouxTina.Web.Domain.Services
@using VentouxTina.Web.Domain.Validation
@using VentouxTina.Web.Infrastructure.DataSources
@inject ITripLogDataSource LogService
@inject ITripLogWriteService WriteService
@inject IProgressService ProgressService
@inject IJSRuntime JS

<section id="logboek" class="section log-section">
    <h2 class="section-title">Activiteitenlogboek</h2>

    @if (_loading)
    {
        <p class="loading-text" aria-busy="true">Logboek laden&hellip;</p>
    }
    else if (_error)
    {
        <p class="error-message" role="alert">
            Het logboek kon niet worden geladen. Probeer de pagina te vernieuwen.
        </p>
    }
    else if (!_entries.Any())
    {
        <p class="info-message">Nog geen activiteiten geregistreerd.</p>
    }
    else
    {
        <table class="log-table" aria-label="Activiteitenlogboek">
            <thead>
            <tr>
                <th scope="col">Datum &amp; tijd</th>
                <th scope="col">Activiteit</th>
                <th scope="col">Kilometers</th>
                <th scope="col" class="col-numeric">Totaal</th>
                <th scope="col" class="col-numeric">%</th>
                <AuthorizeView>
                    <Authorized>
                        <th scope="col"></th>
                    </Authorized>
                </AuthorizeView>
            </tr>
            </thead>
            <tbody>
            @{ var running = 0m; }
            @foreach (var entry in _entries)
            {
                running += entry.Kilometers;
                var pct = _totalKm > 0 ? Math.Min(running / _totalKm * 100m, 100m) : 0m;
                var validation = TripLogValidator.Validate(entry);
                var isLast = entry == _entries[^1];
                <tr class="@(validation.IsValid ? "" : "row-invalid")"
                    title="@(validation.IsValid ? "" : validation.Error)">
                    <td>@entry.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@ActivityLabel(entry.Activity)</td>
                    <td>@entry.Kilometers.ToString("F1") km</td>
                    <td class="col-numeric">@running.ToString("F1") km</td>
                    <td class="col-numeric">@pct.ToString("F1")%</td>
                    <AuthorizeView>
                        <Authorized>
                            <td class="col-action">
                                @if (isLast)
                                {
                                    <button class="btn-delete"
                                            disabled="@_deleting"
                                            title="Verwijder deze activiteit"
                                            @onclick="() => DeleteLastEntry(entry.EntryId)">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="15" height="15" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 0 0 6 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 1 0 .23 1.482l.149-.022.841 10.518A2.75 2.75 0 0 0 7.596 19h4.807a2.75 2.75 0 0 0 2.742-2.53l.841-10.52.149.023a.75.75 0 0 0 .23-1.482A41.03 41.03 0 0 0 14 4.193v-.443A2.75 2.75 0 0 0 11.25 1h-2.5ZM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4ZM8.58 7.72a.75.75 0 0 0-1.5.06l.3 7.5a.75.75 0 1 0 1.5-.06l-.3-7.5Zm4.34.06a.75.75 0 1 0-1.5-.06l-.3 7.5a.75.75 0 1 0 1.5.06l.3-7.5Z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                }
                            </td>
                        </Authorized>
                    </AuthorizeView>
                </tr>
                @if (!validation.IsValid)
                {
                    <tr class="row-validation-error">
                        <td colspan="6" role="alert">
                            <small>Gegevensvalidatiefout: @validation.Error</small>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    }
</section>

@code {
    private IReadOnlyList<TripLogEntry> _entries = [];
    private decimal _totalKm;
    private bool _loading = true;
    private bool _error;
    private bool _deleting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var entriesTask = LogService.GetEntriesAsync();
            var projectionTask = ProgressService.GetProjectionAsync();
            await Task.WhenAll(entriesTask, projectionTask);
            _entries = entriesTask.Result;
            _totalKm = projectionTask.Result?.TotalDistanceKm ?? 0m;
        }
        catch
        {
            _error = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteLastEntry(string entryId)
    {
        _deleting = true;
        try
        {
            await WriteService.DeleteEntryAsync(entryId);
            ProgressService.InvalidateCache();

            // Reload entries in-place
            var entriesTask = LogService.GetEntriesAsync();
            var projectionTask = ProgressService.GetProjectionAsync();
            await Task.WhenAll(entriesTask, projectionTask);
            _entries = entriesTask.Result;
            _totalKm = projectionTask.Result?.TotalDistanceKm ?? 0m;
        }
        catch
        {
            _error = true;
        }
        finally
        {
            _deleting = false;
        }

        await JS.InvokeVoidAsync("scrollToBottom");
    }

    private static string ActivityLabel(string activity) => activity switch
    {
        "running" => "Lopen",
        "cycling" => "Fietsen",
        "walking" => "Wandelen",
        _ => activity,
    };

}

