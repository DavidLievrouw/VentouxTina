@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page">
    <header class="site-header">
        <NavMenu/>
        <button class="dark-mode-toggle"
                aria-label="@(_darkMode ? "Lichte modus" : "Donkere modus")"
                @onclick="ToggleDarkMode">
            @(_darkMode ? "☀️ Licht" : "🌙 Donker")
        </button>
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="site-footer">
        <small>&copy; @DateTime.Now.Year &mdash; Created by David Lievrouw &mdash; ..and lots of AI assistants &mdash; v@{@Version}</small>
    </footer>
</div>

@code {
    private bool _darkMode;
    private static readonly string Version =
        (System.Reflection.CustomAttributeExtensions
            .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>(
                typeof(MainLayout).Assembly)
            ?.InformationalVersion ?? "?")
        .Split('+')[0];

    private async Task ToggleDarkMode()
    {
        _darkMode = !_darkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", _darkMode.ToString());
        await JS.InvokeVoidAsync("setDarkMode", _darkMode);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "darkMode");
            if (stored is "True")
            {
                _darkMode = true;
                // Dark mode class is already applied by app.js on DOMContentLoaded,
                // so we only sync the toggle button state here.
                StateHasChanged();
            }
        }
    }

}
