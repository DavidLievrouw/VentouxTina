@using Microsoft.AspNetCore.Components.Authorization

<nav class="navbar" role="navigation" aria-label="Hoofdnavigatie">
    <button class="nav-hamburger"
            aria-label="Menu openen/sluiten"
            aria-expanded="@_menuOpen"
            aria-controls="nav-links"
            @onclick="ToggleMenu">
        <span></span>
        <span></span>
        <span></span>
    </button>
    <ul id="nav-links" class="nav-links @(_menuOpen ? "nav-links--open" : "")">
        <li><NavLink href="/kaart" Match="NavLinkMatch.All" @onclick="CloseMenu">🗺️ Kaart</NavLink></li>
        <li><NavLink href="/initiatief" @onclick="CloseMenu">💛 Initiatief</NavLink></li>
        <li><NavLink href="/logboek" @onclick="CloseMenu">📋 Logboek</NavLink></li>
        <AuthorizeView>
            <Authorized>
                <li><NavLink href="/beheer/logboek" @onclick="CloseMenu">➕ Toevoegen</NavLink></li>
                <li><NavLink href="/logout" @onclick="CloseMenu">🔓 Uitloggen</NavLink></li>
            </Authorized>
            <NotAuthorized>
                <li><NavLink href="/login" @onclick="CloseMenu">🔑 Inloggen</NavLink></li>
            </NotAuthorized>
        </AuthorizeView>
    </ul>
</nav>

@code {
    private bool _menuOpen;

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;
}

